{
  "entities": {
    "Project": {
      "title": "IoT Project",
      "description": "Represents an IoT project generated by the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the owner" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "skillLevel": { "type": "string", "enum": ["Beginner", "Intermediate", "Advanced"] },
        "budget": { "type": "string" },
        "components": { "type": "array", "items": { "type": "string" } },
        "circuit": {
          "type": "object",
          "properties": {
            "wiring": { "type": "string" },
            "pinMap": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "component": { "type": "string" },
                  "pin": { "type": "string" },
                  "arduinoPin": { "type": "string" }
                }
              }
            }
          }
        },
        "code": {
          "type": "object",
          "properties": {
            "language": { "type": "string" },
            "snippet": { "type": "string" },
            "explanation": { "type": "string" }
          }
        },
        "documentation": {
          "type": "object",
          "properties": {
            "abstract": { "type": "string" },
            "objective": { "type": "string" },
            "working": { "type": "string" },
            "conclusion": { "type": "string" }
          }
        },
        "vivaQuestions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "answer": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "createdAt"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "User IoT projects"
    }
  }
}
